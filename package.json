{
  "name": "palworld-guide",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "npm run build && node --experimental-strip-types --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern .next",
    "data:import": "node scripts/import-pal-data.mjs",
    "data:validate": "node scripts/validate-pal-data.mjs",
    "data:drops:import": "node scripts/import-pal-drops-locations.mjs",
    "data:drops:validate": "node scripts/validate-pal-drops-locations.mjs",
    "data:audit": "node scripts/audit-pal-data.mjs",
    "r2:assets": "node scripts/r2-assets.mjs",
    "r2:audit": "node scripts/r2-audit.mjs",
    "r2:sync": "node scripts/r2-sync.mjs",
    "r2:map": "R2_ASSETS_CONFIG=config/r2-map-assets.json R2_MANIFEST=docs/r2-map-asset-manifest.json node scripts/r2-sync.mjs",
    "r2:pals": "R2_ASSETS_CONFIG=config/r2-pal-assets.json R2_MANIFEST=docs/r2-pal-asset-manifest.json node scripts/r2-sync.mjs",
    "r2:watch": "node scripts/r2-sync.mjs --watch --apply"
  },
  "dependencies": {
    "@fontsource/barlow": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "type": "module"
}
